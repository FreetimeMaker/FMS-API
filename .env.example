# Server Configuration
FMS_HOST=0.0.0.0
FMS_PORT=8000
FMS_DB_PATH=./fms.db
FMS_CORS_ALLOW_ORIGINS=*

# Admin Token (generate a secure random string)
FMS_ADMIN_TOKEN=

# ===== Database Configuration =====
# Option 1: Local SQLite (default - works locally, NOT for Vercel)
# FMS_DB_PATH=./fms.db

# Option 2: Turso/libSQL (for Vercel deployment)
# Get your credentials from https://turso.tech
# TURSO_DB_URL=libsql://your-database-url
# TURSO_DB_AUTH_TOKEN=your-auth-token

# ===== FX Rates Configuration =====
# Provider: no-key (Frankfurter + CoinGecko) or openexchangerates
FMS_FX_PROVIDER=no-key
# For openexchangerates:
# FMS_OER_APP_ID=your-app-id
FMS_FX_INCLUDE_ALTERNATIVE=true
FMS_FX_REFRESH_SECONDS=3600

# CoinGecko IDs for crypto (comma-separated)
FMS_CRYPTO_IDS=bitcoin,ethereum,litecoin,solana,binancecoin,ripple,cardano,polkadot,dogecoin,tron,chainlink,stellar,monero,toncoin,shiba-inu,avalanche-2,uniswap,near,aptos,polygon,pepe,tether,usd-coin
